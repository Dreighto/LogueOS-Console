node_modules

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# Playwright test artifacts (build output, never committed)
test-results/

# Playwright MCP scratch dir — created in cwd whenever the playwright MCP
# server saves output and no --output-dir is set. Per-run, never shared.
.playwright-mcp/

# Per-worker debug artifacts at repo root — left behind by prior debug
# sessions (CC + AGY). Never committed. If you see one of these patterns
# you need to keep, MOVE IT to a real location first (docs/, scripts/, etc.)
# instead of relaxing this ignore.
/test_*.ts
/test_*.js
/test_dir.js
/fix_*.js
/rewrite_*.js
/verify_*.js
/verify_*.png
/fake.png
/find_brace.py
/svelte_lines.txt
/logo_preview.md

# Orchestrator session-state — created by the dispatch listener / loop
# tools when running this repo as a worktree client. Belongs to the
# Orchestrator, not the Console.
/.logueos/

# Stray Windows-path quoted-literal file from the 2026-05-25 Linux migration.
# A `cp` somewhere on Windows wrote a literal `D:\dev\...` filename into the
# repo root. Cannot be removed via git rm (filename contains \ on Linux fs).
"D:\\dev\\LogueOS-Orchestrator\\data\\logueos_memory.db"

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Per-worktree MCP config (written by dispatch_listener at spawn time, never tracked).
# Without this, verifyWorktreeParked rejects the worktree as dirty (untracked
# .mcp.json) and dispatch fails with pre_spawn_dirty_refusal. Mirror LogueOS-Orchestrator.
.mcp.json
mcp.json

# Runtime logs written by start_logueos_console.ps1 (Console server wrapper).
# These accumulate inside the worktree and would otherwise trip the
# dispatch_listener's pre_spawn_dirty_refusal check whenever a new worker
# tries to lease this worktree slot. Set 2026-05-12 after the LOS-9 retry
# bounced on an untracked logs/logueos_console_wrapper.log file.
logs/

# Claude Code preview-server config (per-operator dev tooling, not shared).
.claude/

# Sandbox scratch dir for end-to-end smoke tests (kill switch tmpfs, etc.).
.tmp-*/
.venv-tools/
*.bak.pre-linux
